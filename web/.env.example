# =============================================================
# Image source configuration
# =============================================================
# By default (no env vars set), images are served from web/public/images/
# (bundled with the app). To stream from Azure Blob Storage instead, set
# both variables below. The proxy at /api/image/[...path] uses
# DefaultAzureCredential — NO SAS tokens, NO storage keys.
#
# Locally: `az login` provides credentials.
# In AKS: assign a user-assigned managed identity with the
#         "Storage Blob Data Reader" role on the storage account.

# Public-facing prefix every <Image> src is rewritten to.
# Use "/api/image" to route through the managed-identity proxy.
NEXT_PUBLIC_IMAGE_BASE=/api/image

# Server-only — name of the storage account (no FQDN, no protocol).
AZURE_STORAGE_ACCOUNT=stvinex22travels

# Server-only — blob container holding the /images tree.
AZURE_STORAGE_CONTAINER=images
