# =============================================================
# Cloud variant — Azure Blob Storage via managed identity
# =============================================================
# This variant ALWAYS streams images through /api/image using
# DefaultAzureCredential. NO SAS tokens, NO storage keys.
#
# In AKS: workload identity / user-assigned MI with role
#         "Storage Blob Data Reader" on the storage account.
# Locally: `az login` lets DefaultAzureCredential pick up your user.

NEXT_PUBLIC_IMAGE_BASE=/api/image
AZURE_STORAGE_ACCOUNT=stvinex22travels
AZURE_STORAGE_CONTAINER=images